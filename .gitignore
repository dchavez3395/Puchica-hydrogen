storefrontapi.generated.d.ts

# ─── Tooling lockfiles / scratch ─────────────────────────────
# Local plugin cache + plugin lock — keep out of source control.
.agents/
skills-lock.json
.agent.lock
CLAUDE.local.md

# ─── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
