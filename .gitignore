# ─── Secrets ──────────────────────────────────────────────────
# Never commit environment files. Live tokens for ug91ve-sz.myshopify.com
# live in .env — Storefront API (public + private), Admin OAuth client
# ID + secret, customer account client ID. Treat any leak as compromised.
.env
.env.*
!.env.example

# ─── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp/
.pnp.js

# ─── Build output ─────────────────────────────────────────────
dist/
build/
.cache/

