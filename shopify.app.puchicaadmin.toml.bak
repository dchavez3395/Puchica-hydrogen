# Learn more about configuring your app at https://shopify.dev/docs/apps/tools/cli/configuration

# This TOML is for PuchicaAdmin (app id 387455090689, client_id ddf2d9f5043ddfb4a2baedef8d7a34e5).
# To use it, run:
#   cd E:\Claude\puchica-site && npx shopify app dev --config shopify.app.puchicaadmin.toml
# Then approve the install on a dev store.

client_id = "ddf2d9f5043ddfb4a2baedef8d7a34e5"
application_url = "https://shopify.dev/apps/default-app-home"
embedded = true
name = "PuchicaAdmin"

[webhooks]
api_version = "2026-07"

[access_scopes]
# Full read/write so the runners work end-to-end (gen+upload+featured).
scopes = "write_products,read_products,write_files,read_files,write_publications,read_publications,write_publications,write_themes,read_themes,write_content,read_content,write_metaobject_definitions,read_metaobject_definitions,write_metaobjects,read_metaobjects,write_inventory,read_inventory,write_orders,read_orders,write_fulfillments,read_fulfillments,write_assigned_fulfillment_orders,read_assigned_fulfillment_orders,write_third_party_fulfillment_orders,read_third_party_fulfillment_orders,write_merchant_managed_fulfillment_orders,read_merchant_managed_fulfillment_orders,write_customer_data_erasure,read_customer_data_erasure,write_customer_merge,read_customer_merge,write_customers,read_customers,write_discounts,read_discounts,write_draft_orders,read_draft_orders,write_gift_cards,read_gift_cards,write_gift_card_transactions,read_gift_card_transactions,write_inventory_transfers,read_inventory_transfers,write_inventory_shipments,read_inventory_shipments,write_locations,read_locations,write_markets,read_markets,write_price_rules,read_price_rules,write_product_feeds,read_product_feeds,write_product_listings,read_product_listings,write_purchase_options,read_purchase_options,write_reports,read_reports,write_resource_feedbacks,read_resource_feedbacks,write_script_tags,read_script_tags,write_shipping,read_shipping,write_privacy_settings,read_privacy_settings,write_validations,read_validations,read_analytics,read_assigned_fulfillment_orders,read_app_proxy,read_apps,read_audit_events,read_billing_subscription_contracts,write_billing_subscription_contracts,read_cart_transforms,write_cart_transforms,read_cash_tracking,write_cash_tracking,read_channels,write_channels,read_checkout_branding_settings,write_checkout_branding_settings,read_checkout_and_accounts_configurations,write_checkout_and_accounts_configurations,read_checkouts,write_checkouts,read_companies,write_companies,read_content,write_content,read_custom_fulfillment_services,write_custom_fulfillment_services,read_custom_pixels,write_custom_pixels,read_customer_events,read_customer_payment_methods,read_custom_payment_methods,read_delivery_customizations,write_delivery_customizations,read_delivery_option_generators,write_delivery_option_generators,read_discovery,write_discovery,read_files,write_files,read_fulfillment_constraint_rules,write_fulfillment_constraint_rules,read_legal_policies,write_legal_policies,read_locales,write_locales,read_marketing_events,write_marketing_events,read_marketing_integrated_campaigns,write_marketing_integrated_campaigns,read_own_subscription_contracts,write_own_subscription_contracts,read_order_edits,write_order_edits,read_payment_customizations,write_payment_customizations,read_payment_mandate,write_payment_mandate,read_payment_notifications,write_payment_notifications,read_payment_terms,write_payment_terms,read_pixels,write_pixels,read_publications,write_publications,read_returns,write_returns,read_themes,write_themes,read_translations,write_translations,read_third_party_fulfillment_orders,write_third_party_fulfillment_orders,read_merchant_managed_fulfillment_orders,write_merchant_managed_fulfillment_orders,read_store_credit_accounts,write_store_credit_accounts,read_store_credit_account_transactions,write_store_credit_account_transactions"

[auth]
redirect_urls = [ "https://shopify.dev/apps/default-app-home/api/auth" ]

[build]
include_config_on_deploy = true
automatically_update_urls_on_dev = true